# --- Generation (Claude) ---
# Optional: without a key, ConnectAI uses a deterministic extractive fallback so that
# eval, tests and CI run with zero API cost. Set this locally to use real Claude generation.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embeddings ---
# "sentence-transformers" (default, local, free) or "openai"
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Only used when EMBEDDING_BACKEND=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Reranker ---
RERANK_MODEL=BAAI/bge-reranker-base

# --- Retrieval / gate ---
# Number of candidates pulled from each retriever before fusion
RETRIEVAL_TOP_N=10
# Number of chunks kept after reranking and handed to generation
RERANK_TOP_K=5
# Minimum reranker score for a chunk to count as relevant; below this the agent refuses.
# Calibrated against the eval score distribution (off-topic queries score ~0.50,
# on-topic ~0.52-0.73 with the bge-reranker-base cross-encoder).
MIN_SCORE=0.51

# --- Storage ---
CHROMA_DIR=data/chroma
KB_DIR=data/kb
LOG_FILE=logs/requests.jsonl

# --- Eval gate ---
# CI fails if Hit Rate@K drops below this
EVAL_HIT_RATE_THRESHOLD=0.70
